# DART API 인증키
# https://opendart.fss.or.kr/에서 발급받은 인증키 입력
DART_API_KEY=your_dart_api_key_here

# Flask 설정
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# SSL 인증서 검증
# 사내망(TLS 가로채기/자체서명 인증서) 환경이면 false, 일반 외부망이면 true 권장
VERIFY_SSL=false

# CORS 설정 (프로덕션)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# 데이터 캐싱 (초 단위)
CACHE_TIMEOUT=3600

# 로깅 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
